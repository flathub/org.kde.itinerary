            "name": "kopeninghours",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DBUILD_WITH_QT6=ON"
            ],
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/kopeninghours-25.12.3.tar.xz",
                    "sha256": "674f7dd168679eecbc85d7e68052a0a979f4243a432958a698ba5bbd82178589",
