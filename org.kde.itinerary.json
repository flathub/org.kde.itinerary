{
    "id": "org.kde.itinerary",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "itinerary",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--device=all",
        "--share=network",
        "--talk-name=org.freedesktop.secrets",
        "--talk-name=org.kde.kwalletd5",
        "--talk-name=org.kde.kwalletd6"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/lib/pkgconfig",
        "/mkspecs",
        "/share/qlogging-categories6",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "poppler",
            "config-opts": [
                "-DENABLE_TESTING=OFF",
                "-DENABLE_UNSTABLE_API_ABI_HEADERS=ON",
                "-DENABLE_BOOST=OFF",
                "-DENABLE_CPP=OFF",
                "-DENABLE_GLIB=OFF",
                "-DENABLE_GOBJECT_INTROSPECTION=OFF",
                "-DENABLE_LIBCURL=OFF",
                "-DENABLE_UTILS=OFF",
                "-DENABLE_QT5=OFF",
                "-DENABLE_QT6=OFF",
                "-DENABLE_SPLASH=OFF",
                "-DWITH_Cairo=OFF"
            ],
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://poppler.freedesktop.org/poppler-26.03.0.tar.xz",
                    "sha256": "8b3c5e2a9f2ab4c3ec5029f28af1b433c6b71f0d1e7b3997aa561cf1c0ca4ebe",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 3686,
                        "stable-only": true,
                        "url-template": "https://poppler.freedesktop.org/poppler-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "libphonenumer",
            "buildsystem": "cmake-ninja",
            "subdir": "cpp",
            "config-opts": [
                "-DUSE_BOOST=OFF",
                "-DBUILD_TESTING=OFF",
                "-DREGENERATE_METADATA=OFF",
                "-DBUILD_STATIC_LIB=OFF",
                "-DBUILD_SHARED_LIBS=ON",
                "-DUSE_PROTOBUF_LITE=ON",
                "-DBUILD_GEOCODER=OFF",
                "-DFETCHCONTENT_FULLY_DISCONNECTED=ON",
                "-DCMAKE_POSITION_INDEPENDENT_CODE=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/google/libphonenumber/archive/refs/tags/v9.0.26.tar.gz",
                    "sha256": "f2ac2946d615df52da81f34780ee972fa80af63d1a09becc7b7bbe32ae01547c",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 89344,
                        "stable-only": true,
                        "url-template": "https://github.com/google/libphonenumber/archive/refs/tags/v$version.tar.gz"
                    }
                }
            ],
            "modules": [
                {
                    "name": "protobuf",
                    "buildsystem": "cmake-ninja",
                    "config-opts": [
                        "-Dprotobuf_BUILD_TESTS=OFF",
                        "-Dprotobuf_LOCAL_DEPENDENCIES_ONLY=ON",
                        "-DBUILD_SHARED_LIBS=ON"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://github.com/protocolbuffers/protobuf/archive/refs/tags/v34.1.tar.gz",
                            "sha256": "a83103b7ed3afaeedee9a212c8f65825444f58144f5e075b73c83f2b4ff27b62",
                            "x-checker-data": {
                                "type": "anitya",
                                "project-id": 3715,
                                "stable-only": true,
                                "url-template": "https://github.com/protocolbuffers/protobuf/archive/refs/tags/v$version.tar.gz"
                            }
                        }
                    ],
                    "cleanup": [
                        "/bin",
                        "/lib/libprotobuf.*",
                        "/lib/libprotoc*"
                    ]
                }
            ]
        },
        {
            "name": "qtkeychain",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/frankosterfeld/qtkeychain/archive/0.15.0.tar.gz",
                    "sha256": "f4254dc8f0933b06d90672d683eab08ef770acd8336e44dfa030ce041dc2ca22",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 4138,
                        "stable-only": true,
                        "url-template": "https://github.com/frankosterfeld/qtkeychain/archive/$version.tar.gz"
                    }
                }
            ],
            "config-opts": [
                "-DCMAKE_INSTALL_LIBDIR=/app/lib",
                "-DLIB_INSTALL_DIR=/app/lib",
                "-DBUILD_TRANSLATIONS=NO",
                "-DBUILD_WITH_QT6=ON"
            ]
        },
        {
            "name": "kpkpass",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            ],
            "buildsystem": "cmake-ninja",
            "builddir": true,
