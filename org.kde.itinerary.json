                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kitinerary-$version.tar.xz"
                    }
                }
            ],
            "cleanup": [
                "/lib/libexec"
            ]
        },
        {
            "name": "kpublictransport",
            "config-opts": [
                "-DBUILD_TESTING=OFF"
            ],
            "buildsystem": "cmake-ninja",
            "builddir": true,
