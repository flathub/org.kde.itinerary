                                "url-template": "https://gitlab.matrix.org/matrix-org/olm/-/archive/$version/olm-$version.tar.gz"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "itinerary",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/itinerary-25.12.3.tar.xz",
                    "sha256": "4ceb62714637f02c80dfdcc7995f205f68930bc38ed5e503ef2e29a20016f5aa",
