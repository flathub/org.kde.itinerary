                    }
                }
            ]
        },
        {
            "name": "libQuotient",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/quotient-im/libQuotient/archive/0.9.6.1.tar.gz",
                    "sha256": "ac0fe5df480fa893d3e16da626bf5028c944e9b41f504f6fe0fe49273247d636",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 89357,
                        "stable-only": true,
                        "url-template": "https://github.com/quotient-im/libQuotient/archive/$version.tar.gz"
                    }
                }
            ],
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DQuotient_ENABLE_E2EE=ON",
                "-DBUILD_TESTING=OFF",
                "-DBUILD_WITH_QT6=ON"
            ],
            "cleanup": [
                "/share/ndk-modules"
            ],
            "modules": [
                {
                    "name": "olm",
                    "buildsystem": "cmake-ninja",
                    "builddir": true,
                    "config-opts": [
                        "-DOLM_TESTS=OFF",
                        "-DCMAKE_BUILD_TYPE=Release",
                        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://gitlab.matrix.org/matrix-org/olm/-/archive/3.2.16/olm-3.2.16.tar.gz",
                            "sha256": "1e90f9891009965fd064be747616da46b232086fe270b77605ec9bda34272a68",
                            "x-checker-data": {
                                "type": "anitya",
                                "project-id": 29706,
                                "url-template": "https://gitlab.matrix.org/matrix-org/olm/-/archive/$version/olm-$version.tar.gz"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "itinerary",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/itinerary-26.04.0.tar.xz",
                    "sha256": "f3545b99fbd155ea67a39323d60cd1d00d4fc0d30c63348bf74c5e38d0630433",
